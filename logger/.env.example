# Copy this file to .env and fill in your real values.
# .env is git-ignored — never commit real credentials.

MQTT_BROKER=your-broker.emqxsl.com
MQTT_PORT=8883
MQTT_USER=your-username
MQTT_PASS=your-password
MQTT_SERIAL=YOURSERIAL

# Optional tuning (defaults shown)
WM_SAMPLE_INTERVAL_SEC=15
WM_RETENTION_DAYS=30
WM_EXPORT_PORT=8090

# Recommended if port WM_EXPORT_PORT is reachable from the internet —
# requests must include ?key=<this value> or they get a 403.
WM_EXPORT_KEY=change-me-to-something-random
